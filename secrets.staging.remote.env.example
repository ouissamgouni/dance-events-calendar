# ════════════════════════════════════════════════════════
# REMOTE STAGING SECRETS — copy to secrets.staging.remote.env and fill in real values
# ════════════════════════════════════════════════════════
# Gitignored via secrets.*.env pattern — never committed
# Loaded by: staging:remote tasks only. NEVER loaded by staging:local tasks.
#
# Used by:
#   task db:migrate:staging:remote   — run Alembic migrations on Neon develop branch
#   task db:check:staging:remote     — test connectivity + show migration state
#   task fly:staging:secrets         — push all secrets to the staging Fly.io app
#   task deploy:staging:remote       — full deploy (secrets + migrate + fly + cloudflare)
# ════════════════════════════════════════════════════════

# ── Database (Neon — develop branch) ────────────────────────────
# Get from: Neon dashboard → Project → Branches → develop → Connection string
# Use the pooled connection string (port 5432 with ?sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Google OAuth (admin login) ───────────────────────────────────
# Can reuse prod values or create a separate OAuth client for staging
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Session signing ──────────────────────────────────────────────
# Different from prod — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── CORS (staging frontend URL) ──────────────────────────────────
# Cloudflare Pages preview URL for the develop branch
# Format: https://develop.<project>.pages.dev
CORS_ORIGINS=https://develop.salsa-events-calendar.pages.dev

# ── Frontend build ───────────────────────────────────────────────
# Used by: task deploy:cloudflare:pages (staging variant)
VITE_API_URL=https://salsa-events-calendar-staging.fly.dev

# ── Note: GOOGLE_SERVICE_ACCOUNT_JSON ────────────────────────────
# Do NOT add this here — it contains special characters that break .env parsing.
# task fly:staging:secrets reads it directly from backend/credentials/service-account.json
