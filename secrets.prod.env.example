# ════════════════════════════════════════════════════════
# PRODUCTION SECRETS — copy to secrets.prod.env and fill in real values
# ════════════════════════════════════════════════════════
# NEVER commit this file — gitignored via secrets.*.env pattern
#
# Loading order (later wins):
#   secrets.env → secrets.prod.env → .env.prod
#
# Used by:
#   task db:migrate:prod     — run Alembic migrations against Neon
#   task db:check:prod       — test connectivity + show migration state
#   task fly:secrets         — push all secrets to Fly.io
#   task deploy:cloudflare:pages — build frontend and deploy to Cloudflare Pages
# ════════════════════════════════════════════════════════

# ── Database (Neon) ──────────────────────────────────────────────
# Full connection string from Neon dashboard (Pooled connection recommended)
# Replace POSTGRES_* vars from .env.prod — DATABASE_URL takes precedence
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Google OAuth (admin login) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Session signing ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── CORS (production frontend domain) ────────────────────────────
CORS_ORIGINS=https://yourdomain.com

# ── Frontend build ───────────────────────────────────────────────
# Used by: task deploy:cloudflare:pages (build-time VITE_ var)
VITE_API_URL=https://api.yourdomain.com

# ── SMTP (optional — for event suggestion emails) ────────────────
# Brevo free tier: smtp-relay.brevo.com:587 (300 emails/day)
# Resend free tier: smtp.resend.com:465     (100 emails/day)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── Cloudflare Pages (manual deploy only) ────────────────────────
# Used by: task deploy:cloudflare:pages
# CI deploys automatically via Cloudflare GitHub integration — no token needed there
# Get from: Cloudflare dashboard → My Profile → API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Note: GOOGLE_SERVICE_ACCOUNT_JSON ────────────────────────────
# Do NOT add this here — it contains special characters that break .env parsing.
# task fly:secrets reads it directly from backend/credentials/service-account.json
# and sets it via: fly secrets set GOOGLE_SERVICE_ACCOUNT_JSON="$(cat ...)"
