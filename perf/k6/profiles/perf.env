# BASE_URL is auto-injected by `task perf:run` from the perf scenario's
# state file (.taskfiles/.scenario-state/perf.env → SC_API_PORT).
# This default is only used if the profile is invoked directly via k6.
BASE_URL=http://localhost:8003
ENV=perf
VUS=15
DURATION=2m
RAMP=20s
THINK_MIN=4
THINK_MAX=10
