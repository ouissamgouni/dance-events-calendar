# ════════════════════════════════════════════════════════════════
# Scenario: install-push-prompts
#
# Exercises the PWA "Install app" banner and the post-install "enable
# notifications" banner (InstallPrompt.tsx), plus their admin-only
# force overrides:
#   - force_install_prompt      → bypasses the 14-day install-dismiss
#     snooze and hides the banner's "Not now" button.
#   - force_enable_push_prompt  → bypasses the 24h push-opt-in-dismiss
#     snooze.
#
# No calendar/event data is needed — these banners are purely client-
# side + auth state, so this scenario keeps calendars/events empty.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

# Both banners need web-push "enabled" at the platform level so
# usePush() can resolve past 'disabled' to 'off'/'on'. Uses the shared
# scenario VAPID fallback keypair (config/secrets.scenario.env) — no
# scenario-specific secrets.env needed.
WEB_PUSH_ENABLED=true

# Not under test here; keep other notification pipelines quiet.
NOTIFICATION_SCHEDULER_ENABLED=false
ACTIVITY_DIGEST_EMAIL_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
