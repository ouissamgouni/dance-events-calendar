# ════════════════════════════════════════════════════════════════
# Scenario: reminders-app  (feature × channel matrix cell)
#
# Feature : Event reminders           (EVENT_REMINDERS_ENABLED)
# Channel : In-app only               (email + push disabled)
#
# Asserts that reminder_service creates an in-app `event_reminder`
# row for each `going` attendee of a near-future event while the
# email and push branches inside reminder_service are gated off at
# the per-user level. Digest email pipeline and web-push are also
# OFF at the admin level.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Feature under test.
EVENT_REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240

# Cross-feature isolation.
ACTIVITY_DIGEST_EMAIL_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Channel isolation: web-push disabled globally.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
