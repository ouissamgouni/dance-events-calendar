# Scenario: interest-skip-no-notifications
#
# PRD §13 SCENARIO 2 — verifies that skipping onboarding produces zero
# interest_event notifications, while leaving friend/social digests
# working. Companion to interest-onboarding-international.
CALENDAR_SERVICE=mock
DEV_AUTH=true

# Deliver notifications in-process so the assertions can be observed
# within one minute of triggering.
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

EVENT_REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Master switch is ON — proving the gating relies on "user has no
# profiles" rather than the kill-switch.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=true

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
