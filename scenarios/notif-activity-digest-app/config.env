# ════════════════════════════════════════════════════════════════
# Scenario: activity-digest-app  (feature × channel matrix cell)
#
# Feature : Social-activity digest    (ACTIVITY_DIGEST_EMAIL)
# Channel : In-app only               (email + push disabled)
#
# Asserts that when an actor performs a socially-visible action
# (Alice goes to ev-friend), the attendance service creates a
# `social_activity` in-app row for each of the actor's followers.
# The digest email pipeline is OFF at the admin level so no emails
# or pushes are dispatched — but the in-app rows still fire.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation.
EVENT_REMINDERS_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Feature "in-app" branch is created by the attendance service; the
# digest pipeline (ACTIVITY_DIGEST_EMAIL_ENABLED) is only the email
# and push delivery vehicle. Disable it to prove the in-app rows are
# independent of digest delivery.
ACTIVITY_DIGEST_EMAIL_ENABLED=false

# Channel isolation.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
