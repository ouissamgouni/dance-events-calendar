# ════════════════════════════════════════════════════════════════
# Scenario: reminders-push  (feature × channel matrix cell)
#
# Feature : Event reminders           (EVENT_REMINDERS_ENABLED)
# Channel : Web-push                  (in-app row still created)
#
# Asserts reminder_service creates an in-app row AND dispatches a web-
# push notification to each `going` attendee's subscribed devices for a
# near-future event. Email is disabled per-user so the only outbound
# channel exercised on a subscribed device is push.
#
# Requires: browser step to enable push notifications and create a live
# PushSubscription bound to the recipient's user_id before triggering.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Feature under test.
EVENT_REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240

# Cross-feature isolation.
ACTIVITY_DIGEST_EMAIL_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Channel under test.
WEB_PUSH_ENABLED=true
VAPID_SUBJECT=mailto:admin@example.com

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
