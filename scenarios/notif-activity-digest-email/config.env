# ════════════════════════════════════════════════════════════════
# Scenario: activity-digest-email  (feature × channel matrix cell)
#
# Feature : Social-activity digest    (ACTIVITY_DIGEST_EMAIL)
# Channel : Digest email              (in-app row still created)
#
# Asserts that activity_email delivers a digest email to each follower
# of an actor whose `email_social_activity_enabled` toggle is true.
# In-app rows are created by the attendance service regardless. Push
# is disabled globally and per-user.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation.
EVENT_REMINDERS_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Feature under test.
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Channel isolation.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
