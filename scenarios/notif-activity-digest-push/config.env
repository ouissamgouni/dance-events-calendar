# ════════════════════════════════════════════════════════════════
# Scenario: activity-digest-push  (feature × channel matrix cell)
#
# Feature : Social-activity digest    (ACTIVITY_DIGEST_EMAIL)
# Channel : Web-push                  (in-app row still created)
#
# Asserts that activity_email dispatches web-push notifications to
# each follower's subscribed devices for a social action when the
# follower has `push_social_activity_enabled=true`. Email is disabled
# per-user so the only outbound channel exercised on a subscribed
# device is push.
#
# Requires: browser step to enable push notifications and create a
# live PushSubscription bound to Bob's user_id before triggering.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation.
EVENT_REMINDERS_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Feature under test — digest pipeline handles push dispatch too.
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Channel under test.
WEB_PUSH_ENABLED=true
VAPID_SUBJECT=mailto:admin@example.com

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
