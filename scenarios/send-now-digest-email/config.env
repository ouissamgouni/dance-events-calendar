# ════════════════════════════════════════════════════════════════
# Scenario: send-now-digest-email
#
# Feature : Admin "Send digest now" manual override
#           (POST /api/admin/notifications/digest/send-now)
# Channel : Email (web-push stays disabled so the only observable
#           outbound delivery is Mailpit).
#
# The in-app scheduler loop is disabled entirely
# (NOTIFICATION_SCHEDULER_ENABLED=false), so the pending
# social-activity notification created at seed time can ONLY be
# emailed by the admin's manual "Send digest now" action in this
# scenario — proving the endpoint itself (not a background tick)
# delivers the message, and that delivery is scoped to the
# hand-picked user_ids only, not "everyone eligible".
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

# No background dispatch loop at all — see header comment.
NOTIFICATION_SCHEDULER_ENABLED=false

# Cross-feature isolation.
EVENT_REMINDERS_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Feature under test (delivery vehicle for the admin action).
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Channel isolation.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
