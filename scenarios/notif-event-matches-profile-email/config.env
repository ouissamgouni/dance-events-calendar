# ════════════════════════════════════════════════════════════════
# Scenario: profile-match-email  (feature × channel matrix cell)
#
# Feature : Interest-profile matches      (INTEREST_MATCH_NOTIFICATIONS)
# Channel : Digest email                  (in-app row still created)
#
# Asserts that when a user has interest profile(s) matching seeded
# events, the interest_notification_service creates in-app rows AND
# activity_email delivers a single "Interest matches" digest email
# per matched user via Mailpit. Web-push is disabled globally so no
# push is delivered, isolating the email channel.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation: reminders off, digest pipeline on (needed
# for interest-match email delivery — activity_email is the delivery
# vehicle for interest_event rows).
EVENT_REMINDERS_ENABLED=false
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Feature under test.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=true

# Channel isolation: web-push disabled globally.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
