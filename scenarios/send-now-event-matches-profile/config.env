# ════════════════════════════════════════════════════════════════
# Scenario: send-now-event-matches-profile
#
# Feature : Admin "Force-send interest matches" manual override
#           (POST /api/admin/notifications/interest-match/force-send)
# Channels: ALL THREE — in-app, email AND web-push together. Unlike
#           the notif-event-matches-profile-email/-push scenarios
#           (which isolate one channel each to test the automatic
#           matcher), this scenario's name has no channel suffix on
#           purpose: it exists to confirm the admin force-send action
#           itself fans out to every channel a recipient has enabled,
#           exactly like the normal digest delivery path.
#
# Both the scheduler loop and the global interest-match feature flag
# are disabled, so the ONLY way any interest_event row/email/push is
# created is the admin's manual force-send action — proving the
# endpoint intentionally bypasses both the enable/disable gate and
# the shared scan cursor for the hand-picked users it targets.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

# No background dispatch loop at all — see header comment.
NOTIFICATION_SCHEDULER_ENABLED=false

# Cross-feature isolation.
EVENT_REMINDERS_ENABLED=false

# Global feature gate is OFF on purpose: force-send must still work
# (it bypasses this flag), while the automatic matcher never fires.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Delivery vehicle for interest_event rows on both email and push.
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Push channel under test alongside email.
WEB_PUSH_ENABLED=true
VAPID_SUBJECT=mailto:admin@example.com

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
