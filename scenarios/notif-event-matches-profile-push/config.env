# ════════════════════════════════════════════════════════════════
# Scenario: profile-match-push  (feature × channel matrix cell)
#
# Feature : Interest-profile matches      (INTEREST_MATCH_NOTIFICATIONS)
# Channel : Web-push                      (in-app row still created)
#
# Asserts that when a user has interest profile(s) matching seeded
# events, the interest_notification_service creates in-app rows AND
# activity_email dispatches web-push notifications to subscribed
# devices for that recipient. Email is disabled per-user so the only
# outbound channel exercised is push.
#
# Requires: browser step to enable notifications and produce a live
# push subscription before triggering the dispatch (see test_plan.yaml).
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation: reminders off, digest pipeline on (needed
# for interest-match push dispatch — activity_email is the delivery
# vehicle for interest_event rows on both email and push).
EVENT_REMINDERS_ENABLED=false
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Feature under test.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=true

# Channel under test.
WEB_PUSH_ENABLED=true
VAPID_SUBJECT=mailto:admin@example.com

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
