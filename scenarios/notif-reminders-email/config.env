# ════════════════════════════════════════════════════════════════
# Scenario: reminders-email  (feature × channel matrix cell)
#
# Feature : Event reminders           (EVENT_REMINDERS_ENABLED)
# Channel : Reminder email            (in-app row still created)
#
# Asserts reminder_service creates an in-app row AND sends a per-event
# reminder email to each `going` attendee via Mailpit. Push is disabled
# both globally and per-user so the only outbound is email.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Feature under test.
EVENT_REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240

# Cross-feature isolation.
ACTIVITY_DIGEST_EMAIL_ENABLED=false
INTEREST_MATCH_NOTIFICATIONS_ENABLED=false

# Channel isolation: web-push disabled globally.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
