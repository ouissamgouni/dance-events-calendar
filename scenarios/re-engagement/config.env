CALENDAR_SERVICE=mock
DEV_AUTH=true

# Run user-facing delivery in-process for scenario validation.
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Reminders + activity digest email
REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240
ACTIVITY_EMAIL_ENABLED=true

# Web-push / PWA
WEBPUSH_ENABLED=true
VAPID_SUBJECT=mailto:admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Admin user (required by require_admin dependency and admin trigger endpoint)
ADMIN_EMAIL=admin@example.com

# Local SMTP catcher — Mailpit on port 1025 (web UI: http://127.0.0.1:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
