CALENDAR_SERVICE=mock
DEV_AUTH=true

# Enables in-app social_activity notification fan-out to friends when
# the signed-in submitter of a suggested event marks themselves "going"
# with a "friends" audience.
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
