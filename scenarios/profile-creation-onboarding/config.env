# Scenario: interest-onboarding-international
#
# Full E2E validation of the Interest Profiles PRD happy path
# (PRD §13 SCENARIO 1 + §11 behavior contract + §11b edge cases).
#
# Newbie signs in, is guided through the international-first onboarding
# (Step 1 wide intl profile + Step 2 optional local profile), then a set
# of seeded events exercises every matching + dedup + gating branch of
# the interest_notification_service.
CALENDAR_SERVICE=mock
DEV_AUTH=true

# Run the notification dispatcher in-process every minute so scheduler
# ticks pick up newly ingested events without manual intervention.
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Fold interest_event delivery into the activity email digest.
EVENT_REMINDERS_ENABLED=true
REMINDER_LEAD_HOURS=240
ACTIVITY_DIGEST_EMAIL_ENABLED=true

# Interest-notification kill switch: ON so we exercise the real path.
# Flip to false in a step to verify the master switch honors opt-out.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=true

# Admin user (require_admin dependency + POST /api/admin/trigger-notifications)
ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173

# Local SMTP catcher — Mailpit on port 1025 (web UI: http://127.0.0.1:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
