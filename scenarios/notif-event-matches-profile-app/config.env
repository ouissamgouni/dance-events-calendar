# ════════════════════════════════════════════════════════════════
# Scenario: profile-match-app  (feature × channel matrix cell)
#
# Feature : Interest-profile matches      (INTEREST_MATCH_NOTIFICATIONS)
# Channel : In-app only                   (email + push disabled)
#
# Asserts that when a user has interest profile(s) matching seeded
# events, the pipeline creates in-app `interest_event` notification
# rows *unconditionally* (Phase G rule: rows always fire) — while
# the activity-digest email pipeline and web-push are both switched
# OFF at the admin level so no email is sent and no push is delivered.
# ════════════════════════════════════════════════════════════════
CALENDAR_SERVICE=mock
DEV_AUTH=true

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_INTERVAL_MINUTES=1

# Cross-feature isolation: reminders + digest email off.
EVENT_REMINDERS_ENABLED=false
ACTIVITY_DIGEST_EMAIL_ENABLED=false

# Feature under test.
INTEREST_MATCH_NOTIFICATIONS_ENABLED=true

# Channel isolation: web-push globally disabled.
WEB_PUSH_ENABLED=false

ADMIN_EMAIL=admin@example.com
PUBLIC_APP_URL=http://localhost:5173
