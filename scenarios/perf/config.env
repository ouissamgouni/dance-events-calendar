# Perf-test scenario: deterministic mock data, rate limit disabled, auto-sync on.
# Used by `task perf:scenario:up` and the perf k6 harness.
CALENDAR_SERVICE=mock
AUTO_SYNC_ENABLED=true
# Disable per-IP rate limits so a 15-VU load test from a single host actually
# measures the application instead of the limiter.
RATE_LIMIT_ENABLED=false
