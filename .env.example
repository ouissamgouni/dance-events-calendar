# ════════════════════════════════════════════════════════
# ENVIRONMENT
# ════════════════════════════════════════════════════════
# This is the per-environment config file. Secrets live in secrets.env (gitignored).
#
# Loading order (later wins):
#   secrets.env → secrets.{env}.env → .env.{env} → scenario secrets.env
#
# See secrets.env.example for the secrets template.
# ════════════════════════════════════════════════════════
ENV_NAME=dev

# ════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════
POSTGRES_USER=calendar_user
POSTGRES_PASSWORD=calendar_password
POSTGRES_DB=calendar_db_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
# DATABASE_URL=postgresql://user:password@host:port/database  # overrides above

# ════════════════════════════════════════════════════════
# CALENDAR SERVICE (google | mock)
# ════════════════════════════════════════════════════════
CALENDAR_SERVICE=google

# ════════════════════════════════════════════════════════
# SERVICES
# ════════════════════════════════════════════════════════
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173

# ════════════════════════════════════════════════════════
# UMAMI (analytics)
# ════════════════════════════════════════════════════════
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=

# ════════════════════════════════════════════════════════
# SYNC
# ════════════════════════════════════════════════════════
SYNC_INTERVAL_MINUTES=15
