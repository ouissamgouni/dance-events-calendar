# ════════════════════════════════════════════════════════════════
# REMOTE STAGING SECRETS TEMPLATE — copy to config/secrets.staging.env
# Gitignored — never commit.
# Loaded by: staging:remote tasks only. NEVER loaded by staging:local tasks.
#
# Used by:
#   task db:migrate:staging:remote   — run Alembic migrations on Neon develop branch
#   task db:check:staging:remote     — test connectivity + migration state
#   task fly:staging:secrets         — push secrets to staging Fly.io app
#   task deploy:staging:remote       — full deploy (migrate + fly + cloudflare)
#
# Non-secret remote staging config (CORS_ORIGINS, VITE_*) lives in
# config/staging.remote.env (committed) and config/fly.staging.toml.
# ════════════════════════════════════════════════════════════════

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Database (Neon — develop branch) ────────────────────────────
# Get from: Neon dashboard → Branches → develop → Connection Details → Pooled connection string
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Session signing ──────────────────────────────────────────────
# Different from prod — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── Umami Cloud API key (optional) ───────────────────────────────
# Required only by `task analytics:reset:umami ENV=staging` to wipe
# Umami Cloud data via API. Get one at: https://cloud.umami.is → Settings → API.
UMAMI_API_KEY=

# ── Web Push (VAPID keys for push notifications) ──────────────────
# Generate new keypair with: npm install -g web-push && web-push generate-vapid-keys
# Staging uses different keys from prod. Store public key in config, private here (secret).
WEBPUSH_ENABLED=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
