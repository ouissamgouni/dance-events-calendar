# ════════════════════════════════════════════════════════════════
# DEV SECRETS TEMPLATE — copy to config/secrets.dev.env
# Gitignored — never commit.
# ════════════════════════════════════════════════════════════════

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Session signing ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── Umami analytics (self-hosted, local Docker) ──────────────────
VITE_UMAMI_URL=http://localhost:3100
VITE_UMAMI_WEBSITE_ID=
