# ════════════════════════════════════════════════════════════════
# DEV SECRETS TEMPLATE — copy to config/secrets.dev.env and fill in values
# Loaded after config/secrets.env (values here win for dev tasks).
# ════════════════════════════════════════════════════════════════

# ── Session signing ──────────────────────────────────────────────
# Dev value only — use a real secret in staging/prod
SESSION_SECRET=change-me-to-a-random-string

# ── Umami analytics (self-hosted, local Docker) ──────────────────
# 1. task start:dev:db
# 2. Visit http://localhost:3100, log in with admin/umami, create a website
# 3. Copy the website UUID into VITE_UMAMI_WEBSITE_ID below
VITE_UMAMI_URL=http://localhost:3100
VITE_UMAMI_WEBSITE_ID=
