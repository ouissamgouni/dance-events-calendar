# ════════════════════════════════════════════════════════════════
# SHARED SECRETS TEMPLATE — copy to config/secrets.env and fill in values
#
# Contains true secrets shared across all environments.
# Per-environment secrets (DATABASE_URL, SESSION_SECRET, ADMIN_EMAIL, …)
# live in config/secrets.{env}.env.
# Non-secret shared config (SMTP host/port/from, Cloudflare account ID,
# service-account file path) lives in config/base.env.
#
# Loading order (later wins):
#   config/base.env
#   → config/{env}.env
#   → config/secrets.env          ← this file
#   → config/secrets.{env}.env
#
# Gitignore pattern: config/secrets*.env
# ════════════════════════════════════════════════════════════════

# ── Google OAuth (admin login — required when DEV_AUTH=false) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Calendar API (service account JSON, cloud deployments) ─
# Local dev uses GOOGLE_SERVICE_ACCOUNT_FILE from config/base.env.
# task fly:secrets reads service-account.json and sets this automatically.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# ── Google Geocoding API (optional — improves venue geocoding) ────
# Get a key: https://console.cloud.google.com → APIs & Services → Geocoding API
# GOOGLE_GEOCODING_API_KEY=

# ── SMTP credentials (host / port / from live in config/base.env) ─
SMTP_USER=
SMTP_PASSWORD=

# ── Cloudflare API token (account ID lives in config/base.env) ───
# Get from: Cloudflare dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=
