# ════════════════════════════════════════════════════════════════
# SHARED SECRETS TEMPLATE — copy to config/secrets.env and fill in values
#
# Contains secrets shared across all environments.
# Environment-specific secrets live in config/secrets.{env}.env.
#
# Loading order (later wins):
#   config/base.env
#   → config/{env}.env
#   → config/secrets.env          ← this file
#   → config/secrets.{env}.env
#
# Gitignore pattern: config/secrets*.env
# ════════════════════════════════════════════════════════════════

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Google OAuth (admin login — required when MOCK_ADMIN_AUTH=false) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Calendar API (service account) ────────────────────────
# Local dev: file path
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json
# Cloud deployments (Fly.io): set GOOGLE_SERVICE_ACCOUNT_JSON instead
# (task fly:secrets reads service-account.json and sets it automatically)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# ── SMTP (optional — for event suggestion notification emails) ────
# Brevo free tier: smtp-relay.brevo.com:587 (300 emails/day)
# Resend free tier: smtp.resend.com:465     (100 emails/day)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── Cloudflare Pages (same account for all environments) ─────────
# Used by: task deploy:staging:remote:frontend, task deploy:prod:remote:frontend
# CI deploys use Cloudflare GitHub integration — no token needed there.
# Get from: Cloudflare dashboard → My Profile → API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
