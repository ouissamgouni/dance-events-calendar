# ════════════════════════════════════════════════════════════════
# REMOTE PROD — non-secret config (committed)
# Loaded by: prod:remote tasks (frontend build for Cloudflare Pages).
# Public, build-time-baked values — not secrets.
#
# Backend runtime env (CORS_ORIGINS, ENV_NAME, CALENDAR_SERVICE) lives in
# config/fly.prod.toml [env]. Secrets live in config/secrets.prod.env.
# ════════════════════════════════════════════════════════════════

# ── Frontend (Vite build args, baked into the bundle) ────────────
VITE_API_URL=https://api.joinmovida.com

# ── Umami analytics (Umami Cloud — prod website) ─────────────────
VITE_UMAMI_URL=https://cloud.umami.is
VITE_UMAMI_WEBSITE_ID=315af1e2-9f99-401c-9325-09e811f75792
