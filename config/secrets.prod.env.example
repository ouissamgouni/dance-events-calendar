# ════════════════════════════════════════════════════════════════
# PRODUCTION SECRETS TEMPLATE — copy to config/secrets.prod.env
# Gitignored — never commit.
#
# Used by:
#   task db:migrate:prod     — run Alembic migrations against Neon
#   task db:check:prod       — test connectivity + show migration state
#   task fly:secrets         — push all secrets to Fly.io
#   task deploy:prod:remote  — full prod deploy (migrate + fly + cloudflare)
# ════════════════════════════════════════════════════════════════

# ── Database (Neon — main branch) ────────────────────────────────
# Full connection string from Neon dashboard (Pooled connection recommended)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Session signing ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── CORS + Frontend API URL ──────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com
VITE_API_URL=https://your-backend.fly.dev

# ── Umami analytics (Umami Cloud — prod website) ─────────────────
# Create a website in https://cloud.umami.is for the prod domain,
# then paste its UUID below. URL is the shared Umami Cloud script host.
VITE_UMAMI_URL=https://cloud.umami.is
VITE_UMAMI_WEBSITE_ID=
