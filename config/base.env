# ════════════════════════════════════════════════════════════════
# BASE CONFIG — committed, no secrets
# Universal defaults applied in all environments.
# Override in config/{env}.env, config/{env}.local.env, etc.
# ════════════════════════════════════════════════════════════════

# ── Database defaults (local dev/test/scenario only) ─────────────
# Remote environments (staging:remote, prod:remote) override DATABASE_URL in config/secrets.*.env
POSTGRES_USER=calendar_user
POSTGRES_PASSWORD=calendar_password

# ── App defaults ─────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15
APP_VERSION=1.0.0

# ── SMTP defaults (Brevo) ────────────────────────────────────────
# Credentials (SMTP_USER / SMTP_PASSWORD) live in config/secrets.env
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_FROM=noreply@joinmovida.com

# ── Google Calendar service account (file path for local dev) ────
# Cloud deployments override with GOOGLE_SERVICE_ACCOUNT_JSON via fly secrets
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# ── Cloudflare Pages (account ID is non-secret; token is in secrets.env) ─
CLOUDFLARE_ACCOUNT_ID=0121edf04a7e09ba07299c727021f10c
