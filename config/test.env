# ════════════════════════════════════════════════════════════════
# TEST CONFIG — committed, no secrets
# Loaded by: task test:unit:backend, task db:setup:integ, etc.
# Assumes dev DB container is running (task start:dev:db).
# ════════════════════════════════════════════════════════════════

ENV_NAME=test

# ── Test database (created inside the dev Docker container) ──────
POSTGRES_DB=calendar_db_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
TEST_DATABASE_URL=postgresql://calendar_user:calendar_password@localhost:5434/calendar_db_test

# ── App behaviour ────────────────────────────────────────────────
CALENDAR_SERVICE=mock
DEV_AUTH=true
SESSION_SECRET=test-secret-change-me
