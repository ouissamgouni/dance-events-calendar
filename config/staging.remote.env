# ════════════════════════════════════════════════════════════════
# REMOTE STAGING — non-secret config (committed)
# Loaded by: staging:remote tasks (frontend build for Cloudflare Pages).
# Public, build-time-baked values — not secrets.
#
# Backend runtime env (CORS_ORIGINS, ENV_NAME, CALENDAR_SERVICE) lives in
# config/fly.staging.toml [env]. Secrets live in config/secrets.staging.env.
# ════════════════════════════════════════════════════════════════

# ── Frontend (Vite build args, baked into the bundle) ────────────
# Same-site API subdomain (CNAME → movida-staging.fly.dev) so the session
# cookie is first-party. Avoids third-party cookie blocking on Chrome/Safari.
VITE_API_URL=https://api-develop.joinmovida.com

# ── Umami analytics (Umami Cloud — staging website) ──────────────
VITE_UMAMI_URL=https://cloud.umami.is
VITE_UMAMI_WEBSITE_ID=d8f3134d-b6e6-4bfc-8f21-528e096a0f0b
