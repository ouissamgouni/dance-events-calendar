# ════════════════════════════════════════════════════════════════
# LOCAL PROD CONFIG — committed, no secrets
# Used by: task start:prod (run prod images locally via docker-compose).
# For remote prod (Neon + Fly.io), see config/secrets.prod.env.
# ════════════════════════════════════════════════════════════════

ENV_NAME=prod

# ── Database (local Docker container, port 5432) ─────────────────
POSTGRES_DB=calendar_db_prod
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Ports ────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── App behaviour ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
CALENDAR_SERVICE=google
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# ── Credentials ──────────────────────────────────────────────────
# Local stack credentials live in config/secrets.prod.local.env (gitignored).
# Remote prod credentials live in config/secrets.prod.env (gitignored).
