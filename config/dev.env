# ════════════════════════════════════════════════════════════════
# DEV CONFIG — committed, no secrets
# Loaded by: task start:dev, task db:migrate:dev, etc.
# Loading order: config/base.env → config/dev.env → config/secrets.env → config/secrets.dev.env
# ════════════════════════════════════════════════════════════════

ENV_NAME=dev

# ── Database (local Docker container, port 5434) ─────────────────
POSTGRES_DB=calendar_db_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# ── Ports ────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── App behaviour ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
CALENDAR_SERVICE=google
DEV_AUTH=true
AUTO_SYNC_SCHEDULER_ENABLED=true
