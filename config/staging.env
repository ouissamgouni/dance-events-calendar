# ════════════════════════════════════════════════════════════════
# LOCAL STAGING CONFIG — committed, no real secrets
# Used by: task start:staging:local, task db:migrate:staging:local, etc.
# For remote staging (Neon + Fly.io), see config/secrets.staging.env.
# ════════════════════════════════════════════════════════════════

ENV_NAME=staging

# ── Database (local Docker container, port 5436) ─────────────────
POSTGRES_DB=calendar_db_staging
POSTGRES_HOST=postgres
POSTGRES_PORT=5436

# Explicit DATABASE_URL for local tasks — always points to localhost:5436
# Remote staging tasks get DATABASE_URL from config/secrets.staging.env (Neon develop branch)
DATABASE_URL=postgresql://calendar_user:calendar_password@localhost:5436/calendar_db_staging

# ── Ports ────────────────────────────────────────────────────────
BACKEND_PORT=8002
FRONTEND_PORT=3001

# ── App behaviour ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001
CALENDAR_SERVICE=mock
SYNC_INTERVAL_MINUTES=15

# ── Credentials ──────────────────────────────────────────────────
# Local stack credentials live in config/secrets.staging.local.env (gitignored).
# Remote staging credentials live in config/secrets.staging.env (gitignored).
