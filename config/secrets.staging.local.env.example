# ════════════════════════════════════════════════════════════════
# LOCAL STAGING SECRETS — gitignored, never commit
# Used only by: task start:staging:local (docker-compose on localhost).
# NOT used by remote staging tasks — those use config/secrets.staging.env.
#
# Copy from config/secrets.staging.local.env.example to get started.
# ════════════════════════════════════════════════════════════════

# ── Session signing (any random string is fine for local testing) ─
SESSION_SECRET=staging-local-secret-change-me

# ── Google OAuth (only needed if DEV_AUTH=false) ──────────
GOOGLE_CLIENT_ID=staging-client-id
GOOGLE_CLIENT_SECRET=staging-client-secret

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
