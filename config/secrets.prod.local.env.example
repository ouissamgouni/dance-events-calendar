# ════════════════════════════════════════════════════════════════
# LOCAL PROD SECRETS — gitignored, never commit
# Used only by: task start:prod (docker-compose on localhost).
# NOT used by remote prod tasks — those use config/secrets.prod.env.
#
# Copy from config/secrets.prod.local.env.example to get started.
# ════════════════════════════════════════════════════════════════

# ── Session signing (any random string is fine for local testing) ─
SESSION_SECRET=prod-local-secret-change-me

# ── Google OAuth (only needed if MOCK_ADMIN_AUTH=false) ──────────
GOOGLE_CLIENT_ID=prod-client-id
GOOGLE_CLIENT_SECRET=prod-client-secret

# ── Admin user ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
