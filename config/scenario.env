# ════════════════════════════════════════════════════════════════
# SCENARIO CONFIG — committed, no secrets
# Loaded by: task start:scenario, task db:seed:scenario, etc.
# Loading order: config/base.env → config/scenario.env → config/secrets.env → config/secrets.scenario.env
#                → scenarios/<name>/config.env → scenarios/<name>/secrets.env
# ════════════════════════════════════════════════════════════════

ENV_NAME=scenario

# Mock admin auth — on by default for all scenarios (bypasses Google OAuth)
DEV_AUTH=true

# Default calendar service for scenarios — individual scenarios override via config.env
CALENDAR_SERVICE=mock

# Verbose backend logs by default for all scenarios — makes ad-hoc manual
# testing/debugging easier. Individual scenarios can override via config.env.
LOG_LEVEL=debug
